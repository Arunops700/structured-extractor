# Copy to `.env` and fill in. The real `.env` is gitignored — never commit it.

# Which backend to use: anthropic | openai
PROVIDER=anthropic

# Credentials (set the one matching PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (override as needed)
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Generation / reliability
MAX_TOKENS=4096
MAX_RETRIES=2
